{
  "framework": null,
  "buildCommand": null,
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/erindyersaxon.github.io/london-visa-tracker/:splat*",
      "destination": "https://www.americanvisaguide.com/:splat*",
      "permanent": true
    },
    {
      "source": "/erindyersaxon.github.io/american-visa-guide/:splat*",
      "destination": "https://www.americanvisaguide.com/:splat*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}